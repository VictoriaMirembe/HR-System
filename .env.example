# Copy this file to .env and fill in real values for local development.

# PostgreSQL connection string. See README.md "Database setup" for how to
# create a local role/database matching this.
DATABASE_URL="postgresql://mci_hr:mci_hr_dev_password@localhost:5432/mci_hr_dev?schema=public"

# Secret key used to sign session JWTs. Generate your own with:
#   openssl rand -base64 32
SESSION_SECRET="REPLACE_ME_RUN_OPENSSL_RAND"

# Base URL used to build links sent in emails (e.g. the employee setup
# link). Defaults to http://localhost:3000 in code if unset.
APP_URL="http://localhost:3000"
