# Copy this file to .env and fill in real values for local development.

# PostgreSQL connection string. See README.md "Database setup" for how to
# create a local role/database matching this.
DATABASE_URL="postgresql://mci_hr:mci_hr_dev_password@localhost:5432/mci_hr_dev?schema=public"

# Secret key used to sign session JWTs. Generate your own with:
#   openssl rand -base64 32
SESSION_SECRET="REPLACE_ME_RUN_OPENSSL_RAND"

# Base URL used to build links sent in emails (e.g. the employee setup
# link). Defaults to http://localhost:3000 in code if unset.
APP_URL="http://localhost:3000"

# Resend API key (https://resend.com/api-keys). If unset, the app falls
# back to logging emails to the server console instead of sending them —
# fine for local dev, but real setup-link emails to new employees require
# this to be set.
RESEND_API_KEY=""

# Sender shown on outgoing emails. Must be on a domain verified in the
# Resend dashboard (https://resend.com/domains) — sends from unverified
# domains are rejected. Defaults to Resend's shared test sender
# (onboarding@resend.dev) if unset, which only delivers to the email
# address on the Resend account itself — fine for testing, not for real
# employees until a real domain is verified.
EMAIL_FROM="MCI HR System <onboarding@resend.dev>"
